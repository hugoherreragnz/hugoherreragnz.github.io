---
/**
 * EducationItem — A single education entry.
 */
import { formatDateRange } from '../../utils/formatDate';

interface Props {
  institution: string;
  degree: string;
  field?: string;
  startDate: Date;
  endDate?: Date;
  description?: string;
  details?: string[];
}

const { institution, degree, field, startDate, endDate, description, details } = Astro.props;
const dateRange = formatDateRange(startDate, endDate);
---

<article class="edu-item">
  <div class="edu-item__dot" aria-hidden="true"></div>

  <div class="edu-item__content">
    <header class="edu-item__header">
      <h3 class="edu-item__degree">{degree}</h3>
      {field && <h3 class="edu-item__degree"> in {field}</h3>}
      <p class="edu-item__institution">{institution}</p>
      <time class="edu-item__date">{dateRange}</time>
    </header>

    {description && <p class="edu-item__description">{description}</p>}

    {
      details && details.length > 0 && (
        <ul class="edu-item__details">
          {details.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .edu-item {
    position: relative;
    padding-left: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .edu-item::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 10px;
    bottom: 0;
    width: 1px;
    background: var(--timeline-color);
  }

  .edu-item:last-child::before {
    display: none;
  }

  .edu-item:last-child {
    padding-bottom: 0;
  }

  .edu-item__dot {
    position: absolute;
    left: 0;
    top: 6px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent);
  }

  .edu-item__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .edu-item__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .edu-item__degree {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-heading);
  }

  .edu-item__institution {
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .edu-item__date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .edu-item__description {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: var(--line-height-normal);
  }

  .edu-item__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding-left: var(--space-sm);
    list-style: disc;
    margin-top: var(--space-2xs);
  }

  .edu-item__details li {
    font-size: var(--font-size-sm);
    color: var(--color-text);
    line-height: var(--line-height-normal);
  }
</style>
