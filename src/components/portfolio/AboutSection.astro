---
/**
 * AboutSection — Bio paragraphs + skills grid.
 */
import Badge from '../ui/Badge.astro';
import { getCollection } from 'astro:content';

const profileEntries = await getCollection('profile');
const profile = profileEntries[0]?.data;
---

{
  profile && (
    <div class="about">
      <div class="about__bio">
        {profile.bio.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <div class="about__skills">
        <h3 class="about__skills-title">Skills e intereses</h3>
        <div class="about__skills-list">
          {profile.skills.map((skill: string) => (
            <Badge>{skill}</Badge>
          ))}
        </div>
      </div>
    </div>
  )
}

<style>
  .about {
    display: grid;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .about {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    font-size: var(--font-size-md);
    color: var(--color-text);
    line-height: var(--line-height-relaxed);
  }

  .about__skills-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .about__skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }
</style>
