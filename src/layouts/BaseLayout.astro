---
/**
 * BaseLayout — The root layout for all pages.
 *
 * Handles:
 * - HTML document structure
 * - SEO meta tags (title, description, Open Graph, Twitter Cards)
 * - CSS imports (base + all themes)
 * - Anti-FOUC theme initialization script
 * - Navbar and Footer
 *
 * Every page should use this layout:
 *   <BaseLayout title="My Page" description="Page description">
 *     <main>...</main>
 *   </BaseLayout>
 */
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, OG_IMAGE, DEFAULT_THEME } from '../utils/constants';

// Import all styles — base + themes
import '../styles/base.css';
import '../styles/themes/classic.css';
import '../styles/themes/bold.css';
import '../styles/themes/mono.css';
import '../styles/themes/retro.css';
import '../styles/themes/futura.css';
import '../styles/themes/finance.css';
import '../styles/themes/quant.css';
import '../styles/themes/math.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage = OG_IMAGE,
  canonicalURL = Astro.url.href,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE.split('—')[0].trim()}`;
---

<!doctype html>
<html lang="en" data-theme={DEFAULT_THEME}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* ─── SEO ─── */}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* ─── Favicon ─── */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    {/* ─── Open Graph ─── */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url).href} />
    <meta property="og:url" content={canonicalURL} />

    {/* ─── Twitter Card ─── */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? Astro.url).href} />

    {/* ─── Fonts ─── */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        const STORAGE_KEY = 'portfolio-theme';
        const DEFAULT_THEME = 'Light mode';
        const params = new URLSearchParams(window.location.search);
        const theme = params.get('theme') || localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME;
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <meta name="generator" content={Astro.generator} />
  </head>

  <body>
    {/* ─── Skip to content (accessibility) ─── */}
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <Navbar />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
